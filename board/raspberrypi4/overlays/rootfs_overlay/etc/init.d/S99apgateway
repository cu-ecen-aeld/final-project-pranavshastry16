#!/bin/sh

case "$1" in
    start)
        echo "[S99apgateway] Starting AP gateway setup"

        # Load Pi Wi-Fi driver
        modprobe brcmfmac
        sleep 2

        # Upstream side on eth0
        ip addr flush dev eth0 2>/dev/null
        ip addr add 192.168.1.2/24 dev eth0
        ip link set eth0 up
        ip route del default 2>/dev/null
        ip route add default via 192.168.1.1

        # Guest Wi-Fi side on wlan0
        ip addr flush dev wlan0 2>/dev/null
        ip addr add 192.168.60.1/24 dev wlan0
        ip link set wlan0 up

        # Enable forwarding
        echo 1 > /proc/sys/net/ipv4/ip_forward

        # Clean old firewall/NAT rules
        iptables -F
        iptables -t nat -F
        iptables -P FORWARD ACCEPT

        # NAT from wlan0 to eth0
        iptables -t nat -A POSTROUTING -o eth0 -j MASQUERADE
        iptables -A FORWARD -i wlan0 -o eth0 -j ACCEPT
        iptables -A FORWARD -i eth0 -o wlan0 -m state --state RELATED,ESTABLISHED -j ACCEPT

        # Stop anything stale
        killall hostapd 2>/dev/null
        killall dnsmasq 2>/dev/null

        # Start services
        hostapd -B /etc/hostapd.conf
        dnsmasq --conf-file=/etc/dnsmasq.conf

        echo "[S99apgateway] AP gateway setup complete"
        ;;
    stop)
        echo "[S99apgateway] Stopping AP gateway setup"

        killall hostapd 2>/dev/null
        killall dnsmasq 2>/dev/null

        iptables -F
        iptables -t nat -F

        echo 0 > /proc/sys/net/ipv4/ip_forward
        ;;
    restart)
        $0 stop
        sleep 1
        $0 start
        ;;
    *)
        echo "Usage: $0 {start|stop|restart}"
        exit 1
        ;;
esac

exit 0
